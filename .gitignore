# ========================
# SKYBEING - Root .gitignore
# ========================

# ─── Environment / Secrets ───────────────────────────────────────────────────
.env
.env.*
!.env.example        # always allow the example template

# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/
**/node_modules/

# ─── Build Output ────────────────────────────────────────────────────────────
dist/
dist-ssr/
build/

# ─── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
backend_log.txt

# ─── OS Generated ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ─── Editor ──────────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── Temp / Misc ─────────────────────────────────────────────────────────────
*.local
*.tmp
test.txt
public/temp/*
!public/temp/.gitkeep
