# Google OAuth Client ID (public — safe to expose in frontend)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Backend API URL — set this to your Cloudflare Worker URL in production
# Leave empty in local dev (Vite proxy handles it automatically)
VITE_API_BASE_URL=https://skybeings-backend.talkwithaman22.workers.dev/api/v1

